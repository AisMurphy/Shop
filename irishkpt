const DIVISIONS = [
  // Per pale (vertical split)
  (p) => `<clipPath id="cp1"><path d="M20,20 L80,20 L80,140 L20,140Z"/></clipPath>
    <rect x="20" y="20" width="120" height="120" fill="${p.bg}"/>
    <rect x="20" y="20" width="60" height="120" fill="${p.accent}" clip-path="url(#cp1)"/>`,
  // Per fess (horizontal split)
  (p) => `<rect x="20" y="20" width="120" height="120" fill="${p.bg}"/>
    <rect x="20" y="20" width="120" height="60" fill="${p.accent}"/>`,
  // Quarterly
  (p) => `<rect x="20" y="20" width="120" height="120" fill="${p.bg}"/>
    <rect x="20" y="20" width="60" height="60" fill="${p.accent}"/>
    <rect x="80" y="80" width="60" height="60" fill="${p.accent}"/>`,
  // Solid
  (p) => `<rect x="20" y="20" width="120" height="120" fill="${p.bg}"/>`,
  // Bendy (diagonal stripe)  
  (p) => `<rect x="20" y="20" width="120" height="120" fill="${p.bg}"/>
    <polygon points="20,20 80,20 140,80 140,140 80,140 20,80" fill="${p.accent}"/>`,
];

function generateCrestSVG(surname, size=160) {
  const h = hashStr(surname);
  const p = CREST_PALETTES[h % CREST_PALETTES.length];
  const div = DIVISIONS[(h >> 4) % DIVISIONS.length];
  const charge = CREST_CHARGES[(h >> 8) % CREST_CHARGES.length];
  const initials = surname.replace(/[^A-Za-z]/g,'').slice(0,2).toUpperCase();

  // Shield path (heater shield shape)
  const shield = `M20,20 L140,20 L140,100 Q140,155 80,170 Q20,155 20,100 Z`;

  return `<svg width="${size}" height="${size}" viewBox="0 0 160 180" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <clipPath id="shield-clip-${h}">
        <path d="${shield}"/>
      </clipPath>
    </defs>
    <!-- Shield field -->
    <g clip-path="url(#shield-clip-${h})">
      ${div(p)}
    </g>
    <!-- Charge -->
    <g clip-path="url(#shield-clip-${h})">
      ${charge(null, p)}
    </g>
    <!-- Shield border -->
    <path d="${shield}" fill="none" stroke="${p.metal}" stroke-width="4"/>
    <!-- Outer border -->
    <path d="${shield}" fill="none" stroke="${p.metal}" stroke-width="1.5" stroke-dasharray="4,3" opacity="0.5"
      transform="scale(0.92) translate(7,7)"/>
    <!-- Surname ribbon -->
    <rect x="10" y="168" width="140" height="18" rx="2" fill="${p.accent}" stroke="${p.metal}" stroke-width="1.5"/>
    <text x="80" y="180" text-anchor="middle" font-family="'Playfair Display', serif"
      font-size="${initials.length > 1 ? 9 : 11}" fill="${p.metal}" font-weight="700"
      letter-spacing="1">${surname.toUpperCase()}</text>
  </svg>`;
}


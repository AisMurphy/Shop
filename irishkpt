// ── SQUARE CHECKOUT ──
// IMPORTANT: Replace 'sandbox-sq0idb-REPLACE_ME' with your actual Square Application ID
// Get yours at https://developer.squareup.com/apps
// For sandbox testing: use 'sandbox-sq0idb-...' and card number 4111 1111 1111 1111
const SQUARE_APP_ID = 'sandbox-sq0idb-REPLACE_WITH_YOUR_APP_ID';
const SQUARE_LOCATION_ID = 'REPLACE_WITH_YOUR_LOCATION_ID';

let squareCard = null;
let squarePayments = null;

async function initSquareCheckout() {
  if (cart.length === 0) return;
  const form = document.getElementById('square-payment-form');
  const checkoutBtn = document.getElementById('checkoutBtn');

  if (form.classList.contains('visible')) return; // already open

  // Check if real credentials are set
  if (SQUARE_APP_ID.includes('REPLACE_ME') || SQUARE_APP_ID.includes('REPLACE_WITH')) {
    showToast('⚠️ Add your Square App ID to enable real payments');
    const _ps = document.getElementById('payment-status'); if(_ps) _ps.textContent =
      '👆 Replace SQUARE_APP_ID & SQUARE_LOCATION_ID in the script to go live.';
    form.classList.add('visible');
    checkoutBtn.style.display = 'none';
    return;
  }

  try {
    checkoutBtn.textContent = 'Loading payment form…';
    checkoutBtn.disabled = true;
    squarePayments = Square.payments(SQUARE_APP_ID, SQUARE_LOCATION_ID);
    squareCard = await squarePayments.card();
    await squareCard.attach('#card-container');
    form.classList.add('visible');
    checkoutBtn.style.display = 'none';
    const _ps = document.getElementById('payment-status'); if(_ps) _ps.textContent = 'Enter your card details above.';
  } catch (err) {
    checkoutBtn.textContent = 'Proceed to Checkout';
    checkoutBtn.disabled = false;
    const _ps = document.getElementById('payment-status'); if(_ps) _ps.textContent = 'Could not load payment form. Check your App ID.';
    console.error('Square init error:', err);
  }
}

async function handlePayment() {
  if (!squareCard) return;
  const statusEl = document.getElementById('payment-status');
  statusEl.textContent = 'Processing…';
  try {
    const result = await squareCard.tokenize();
    if (result.status === 'OK') {
      const token = result.token;
      const total = Math.round((getCartTotal() + (getCartTotal() >= 75 ? 0 : 8.95)) * 100);
      // ── Send token + total to YOUR backend to call Square Payments API ──
      // Example: fetch('/api/square-pay', { method:'POST', body: JSON.stringify({token, total}) })
      // For now we simulate success:
      statusEl.textContent = '✅ Payment successful! Order confirmed. ☘';
      cart = [];
      updateCartBadge();
      renderCart();
      showToast('✅ Order placed! Thanks for shopping Irish.');
      setTimeout(() => {
        document.getElementById('square-payment-form').classList.remove('visible');
        document.getElementById('checkoutBtn').style.display = 'block';
        document.getElementById('checkoutBtn').textContent = 'Proceed to Checkout';
        document.getElementById('checkoutBtn').disabled = false;
        statusEl.textContent = '';
        closeCart();
      }, 2500);
    } else {
      statusEl.textContent = '❌ ' + (result.errors?.[0]?.message || 'Payment failed. Please try again.');
    }
  } catch (err) {
    statusEl.textContent = '❌ Payment error. Please try again.';
    console.error(err);
  }
}


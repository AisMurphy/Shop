  'Connemara Marble': {color:'#00695C',emoji:'💚',desc:"Ireland's unique gemstone"},
  "St Bridget\'s Cross": {color:'#4527A0',emoji:'✚',desc:'Ancient Irish protection'},
  'Harp': {color:'#1565C0',emoji:'🎵',desc:'Irish identity & pride'},
  'Birthstone': {color:'#7B1FA2',emoji:'💎',desc:'Your birth month, your stone'},
};

let activeSymbol = null;

function enquireSymbolLink(item) {
  const subject = encodeURIComponent('Enquiry: ' + item.n);
  const body = encodeURIComponent('Hi,\n\nI\'m interested in the ' + item.n + ' ($' + item.p.toFixed(2) + (item.s ? ', SKU: ' + item.s : '') + '). Could you let me know if it\'s in stock?\n\nThanks');
  return 'mailto:hiya@theirishstorekpt.com?subject=' + subject + '&body=' + body;
}

function renderSymbolCard(item) {
  const meta = item.sym.length ? SYMBOL_META[item.sym[0]] : null;
  const color = meta ? meta.color : '#1B5E20';
  return `<div style="background:white;border:1.5px solid #e0dbd0;border-top:3px solid ${color};border-radius:3px;display:flex;flex-direction:column;overflow:hidden;transition:box-shadow 0.2s;"
    onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow='none'">
    <div style="padding:0.85rem 0.85rem 0.4rem;flex:1;">
      <div style="display:flex;flex-wrap:wrap;gap:0.25rem;margin-bottom:0.4rem;">
        ${item.sym.slice(0,2).map(s => `<span style="font-size:0.58rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
          color:${SYMBOL_META[s]?.color||'#888'};background:${SYMBOL_META[s]?.color||'#888'}11;
          padding:0.15rem 0.45rem;border-radius:20px;">${SYMBOL_META[s]?.emoji||''} ${s}</span>`).join('')}
      </div>
      <div style="font-size:0.83rem;font-weight:700;color:#1C1C1C;line-height:1.3;margin-bottom:0.35rem;">${item.n}</div>
      <div style="font-size:0.73rem;color:#888;line-height:1.55;">${item.d}</div>
    </div>
    <div style="padding:0.6rem 0.85rem;border-top:1px solid #f0ebe0;display:flex;align-items:center;justify-content:space-between;background:#fafaf8;">
      <div style="font-size:0.95rem;font-weight:800;color:#1B5E20;font-family:'Playfair Display',serif;">$${item.p.toFixed(2)}</div>
      <a href="${enquireSymbolLink(item)}" style="background:#1B5E20;color:white;text-decoration:none;padding:0.3rem 0.7rem;border-radius:2px;font-size:0.68rem;font-weight:700;letter-spacing:0.05em;">✉ Enquire</a>
    </div>
  </div>`;
}

function filterBySymbol(symbol) {
  activeSymbol = symbol;
  const input = document.getElementById('symbolSearchInput');
  if (input) input.value = '';

  const banner = document.getElementById('symbolBanner');
  const bannerText = document.getElementById('symbolBannerText');

  if (symbol) {
    const meta = SYMBOL_META[symbol];
    banner.style.display = 'flex';
    bannerText.textContent = (meta?.emoji || '') + ' Showing all ' + symbol + ' items — ' + (meta?.desc || '');
  } else {
    banner.style.display = 'none';
  }

  renderSymbolResults(symbol ? SYMBOL_ITEMS.filter(i => i.sym.includes(symbol)) : SYMBOL_ITEMS);
}

function handleSymbolSearch(q) {
  activeSymbol = null;
  document.getElementById('symbolBanner').style.display = 'none';
  if (!q.trim()) {
    renderSymbolResults(SYMBOL_ITEMS);
    return;
  }
  const ql = q.toLowerCase();
  // Match by symbol name, item name, or description
  const matches = SYMBOL_ITEMS.filter(i =>
    i.n.toLowerCase().includes(ql) ||
    i.d.toLowerCase().includes(ql) ||
    i.sym.some(s => s.toLowerCase().includes(ql))
  );
  renderSymbolResults(matches);
}

function renderSymbolResults(items) {
  const grid = document.getElementById('symbolGrid');
  const empty = document.getElementById('symbolEmpty');
  const count = document.getElementById('symbolCount');
  if (!grid) return;
  if (items.length === 0) {
    grid.innerHTML = '';
    empty.style.display = 'block';
    count.textContent = '';
  } else {
    grid.innerHTML = items.slice(0, 48).map(renderSymbolCard).join('');
    empty.style.display = 'none';
    count.textContent = items.length + ' items found' + (items.length > 48 ? ' (showing first 48)' : '');
  }
}

// Init on load
document.addEventListener('DOMContentLoaded', () => renderSymbolResults(SYMBOL_ITEMS));
</script>


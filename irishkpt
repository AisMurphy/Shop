let selectedSurname = null;

function initHeraldicSearch() {
  const input = document.getElementById('surnameInput');
  const dropdown = document.getElementById('surnameDropdown');

  input.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    if (!q) { dropdown.classList.remove('open'); return; }
    const matches = uniqueSurnames.filter(s => s.toLowerCase().startsWith(q)).slice(0, 12);
    if (matches.length === 0) {
      dropdown.innerHTML = `<div class="surname-no-match">No results found</div>`;
    } else {
      dropdown.innerHTML = matches.map(s =>
        `<div class="surname-option" onclick="selectSurname('${s.replace(/'/g,"\\'")}')">
          <span class="crest-icon">🏰</span> ${s}
        </div>`
      ).join('');
    }
    dropdown.classList.add('open');
  });

  input.addEventListener('keydown', e => {
    if (e.key === 'Escape') { dropdown.classList.remove('open'); input.value = ''; hideHeraldicResult(); }
  });

  document.addEventListener('click', e => {
    if (!document.querySelector('.heraldic-search-wrap').contains(e.target)) {
      dropdown.classList.remove('open');
    }
  });
}

function selectSurname(name) {
  selectedSurname = name;
  document.getElementById('surnameInput').value = name;
  document.getElementById('surnameDropdown').classList.remove('open');
  showHeraldicProducts(name);
}

function showHeraldicProducts(name) {
  const result = document.getElementById('heraldicResult');
  if (!result) return;
  result.innerHTML = `
    <div class="heraldic-products">
      ${heraldicItems.map((item, i) => `
        <div class="heraldic-card">
          <div class="heraldic-card-img">
            ${item.emoji}
            <div class="h-badge">${item.badge}</div>
          </div>
          <div class="heraldic-card-body">
            <div class="heraldic-card-name">${item.label}</div>
            <div class="heraldic-card-desc">${item.desc}</div>
            <div class="heraldic-card-price">$${item.price.toFixed(2)}</div>
            <button class="btn-heraldic-add" onclick="addHeraldicToCart('${name.replace(/'/g,"\\'")}','${item.label}','${item.emoji}',${item.price})">
              Add to Cart
            </button>
          </div>
        </div>
      `).join('')}
    </div>
  `;
  result.classList.add('visible');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function hideHeraldicResult() {
  const result = document.getElementById('heraldicResult');
  result.classList.remove('visible');
  selectedSurname = null;
}

function addHeraldicToCart(surname, itemLabel, emoji, price) {
  const name = `${itemLabel} — ${surname}`;
  // Give heraldic items unique IDs starting at 1000
  const id = 1000 + heraldicItems.findIndex(i => i.label === itemLabel);
  const existing = cart.find(i => i.name === name);
  if (existing) { existing.qty += 1; }
  else { cart.push({ id, name, price, emoji, qty: 1 }); }
  updateCartBadge();
  renderCart();
  showToast(`☘ "${name}" added to cart!`);
}


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Irish Store of Kennebunkport</title>
  <link rel="canonical" href="https://www.theirishstorekpt.com" />
  <meta name="description" content="The Irish Store of Kennebunkport — Owned by a Real Galway Girl. Authentic Irish knitwear, heraldic souvenirs, jewelry & gifts. Dock Square, Kennebunkport, ME." />
  <meta property="og:title" content="The Irish Store of Kennebunkport" />
  <meta property="og:description" content="Owned by a Real Galway Girl. Authentic Irish goods at Dock Square, Kennebunkport, Maine." />
  <meta property="og:url" content="https://www.theirishstorekpt.com" />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="The Irish Store of Kennebunkport" />
  <meta name="twitter:description" content="Owned by a Real Galway Girl. Authentic Irish goods at Dock Square, Kennebunkport, Maine." />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- Square SDK hidden with cart — uncomment to re-enable payments
  <script src="https://sandbox.web.squarecdn.com/v1/square.js"></script>
  -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --green-deep: #1B5E20;
      --green-mid: #2E7D32;
      --green-light: #388E3C;
      --gold: #C9A84C;
      --gold-light: #E2C26E;
      --cream: #FAF7F0;
      --cream-dark: #F0EBE0;
      --charcoal: #1C1C1C;
      --white: #ffffff;
    }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', sans-serif; background: var(--cream); color: var(--charcoal); }

    /* ── NAV ── */
    nav {
      background: var(--green-deep);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 64px;
      position: sticky;
      top: 0;
      z-index: 200;
      border-bottom: 3px solid var(--gold);
      gap: 1rem;
    }
    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-size: 1.15rem;
      color: var(--gold);
      font-weight: 700;
      letter-spacing: 0.02em;
      line-height: 1.2;
      flex-shrink: 0;
    }
    .nav-logo span { display: block; color: var(--white); font-size: 0.65rem; font-family: 'Inter', sans-serif; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; }
    .nav-links { display: flex; gap: 1.5rem; list-style: none; flex-shrink: 0; }
    .nav-links a { color: var(--cream); text-decoration: none; font-size: 0.82rem; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s; }
    .nav-links a:hover { color: var(--gold); }

    /* Search bar */
    /* Search results dropdown */
    .sri-emoji { font-size: 1.6rem; width: 2.2rem; text-align: center; flex-shrink: 0; }
    .sri-info { flex: 1; }
    .sri-name { font-size: 0.85rem; font-weight: 600; color: var(--charcoal); }
    .sri-cat { font-size: 0.72rem; color: var(--green-light); letter-spacing: 0.05em; }
    .sri-price { font-size: 0.88rem; font-weight: 700; color: var(--green-deep); flex-shrink: 0; }
    .sri-section-label {
      padding: 0.4rem 1rem 0.25rem;
      font-size: 0.65rem; font-weight: 700; letter-spacing: 0.15em;
      text-transform: uppercase; color: var(--gold);
      background: var(--cream-dark); border-bottom: 1px solid #e0d9ce;
    }

    .nav-right { display: flex; align-items: center; gap: 0.75rem; flex-shrink: 0; }
    .nav-cart-btn {
      background: var(--gold);
      color: var(--green-deep);
      border: none;
      padding: 0.45rem 1rem;
      border-radius: 2px;
      font-size: 0.8rem;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      transition: background 0.2s;
      white-space: nowrap;
    }
    .nav-cart-btn:hover { background: var(--gold-light); }

    /* ── HERO ── */
    .hero {
      position: relative;
      min-height: 560px;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: var(--green-deep);
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at 70% 50%, #2E7D3288 0%, transparent 60%),
                  linear-gradient(135deg, #1B5E20 0%, #0d3311 100%);
    }
    .hero-pattern {
      position: absolute; right: -40px; top: 50%; transform: translateY(-50%);
      width: 480px; height: 480px; opacity: 0.08;
    }
    .hero-content { position: relative; z-index: 2; padding: 4rem 2rem 4rem 6vw; max-width: 680px; }
    .hero-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .hero-title { font-family: 'Playfair Display', serif; font-size: clamp(2.4rem, 5.5vw, 4.2rem); color: var(--white); line-height: 1.08; font-weight: 900; margin-bottom: 1.1rem; }
    .hero-title em { color: var(--gold); font-style: italic; }
    .hero-sub { font-size: 1rem; color: #c8e6c9; line-height: 1.65; max-width: 480px; margin-bottom: 2rem; font-weight: 300; }
    .hero-cta { display: inline-flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary { background: var(--gold); color: var(--green-deep); border: none; padding: 0.85rem 2rem; font-size: 0.88rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s, transform 0.15s; text-decoration: none; display: inline-block; }
    .btn-primary:hover { background: var(--gold-light); transform: translateY(-2px); }
    .btn-secondary { background: transparent; color: var(--white); border: 2px solid rgba(255,255,255,0.4); padding: 0.85rem 2rem; font-size: 0.88rem; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: border-color 0.2s, color 0.2s; text-decoration: none; display: inline-block; }
    .btn-secondary:hover { border-color: var(--gold); color: var(--gold); }

    /* ── TRUST BANNER ── */
    .trust-banner { background: var(--green-mid); border-top: 2px solid var(--gold); border-bottom: 2px solid var(--gold); display: flex; justify-content: center; gap: 2.5rem; padding: 0.8rem 2rem; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 0.5rem; color: var(--cream); font-size: 0.78rem; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase; }
    .trust-item .icon { font-size: 1rem; }

    /* ── SECTION SHELL ── */
    section { padding: 4rem 2rem; }
    .section-header { text-align: center; margin-bottom: 2.5rem; }
    .section-eyebrow { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
    .section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 4vw, 2.4rem); color: var(--green-deep); font-weight: 900; line-height: 1.15; }

    /* ── CATEGORIES ── */
    .categories { background: var(--cream-dark); }
    .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1rem; max-width: 1100px; margin: 0 auto; }
    .cat-card { position: relative; height: 210px; border-radius: 3px; overflow: hidden; cursor: pointer; display: flex; align-items: flex-end; }
    .cat-bg { position: absolute; inset: 0; transition: transform 0.4s ease; }
    .cat-card:hover .cat-bg { transform: scale(1.06); }
    .cat-card:nth-child(1) .cat-bg { background: linear-gradient(135deg,#1B5E20,#2d8a35); }
    .cat-card:nth-child(2) .cat-bg { background: linear-gradient(135deg,#4E342E,#795548); }
    .cat-card:nth-child(3) .cat-bg { background: linear-gradient(135deg,#1A237E,#283593); }
    .cat-card:nth-child(4) .cat-bg { background: linear-gradient(135deg,#880E4F,#AD1457); }
    .cat-card:nth-child(5) .cat-bg { background: linear-gradient(135deg,#E65100,#F57C00); }
    .cat-emoji { display: none; }
    .cat-illustration {
      position: absolute; top: 50%; left: 50%;
      transform: translate(-50%, -62%);
      width: 140px; height: 120px;
      pointer-events: none;
    }
    .cat-illustration svg { width: 100%; height: 100%; }
    .cat-label { position: relative; z-index: 2; width: 100%; background: linear-gradient(transparent,rgba(0,0,0,0.7)); padding: 1.5rem 1rem 1rem; color: var(--white); }
    .cat-label strong { font-family: 'Playfair Display', serif; font-size: 1rem; display: block; }
    .cat-label span { font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--gold-light); }

    /* ── PRODUCTS ── */
    .products { background: var(--cream); }
    .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }
    .no-results { grid-column: 1/-1; text-align: center; padding: 3rem; color: #888; font-size: 1rem; }
    .product-card { background: var(--white); border: 1px solid #e0d9ce; border-radius: 3px; overflow: hidden; transition: box-shadow 0.25s, transform 0.2s; cursor: pointer; }
    .product-card:hover { box-shadow: 0 8px 32px rgba(27,94,32,0.13); transform: translateY(-4px); }
    .product-img { height: 210px; display: flex; align-items: center; justify-content: center; font-size: 4rem; position: relative; overflow: hidden; }
    .product-badge { position: absolute; top: 0.75rem; left: 0.75rem; background: var(--gold); color: var(--green-deep); font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.2rem 0.5rem; border-radius: 1px; }
    .product-body { padding: 1rem 1.1rem 1.2rem; }
    .product-category { font-size: 0.66rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green-light); margin-bottom: 0.3rem; }
    .product-name { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.3rem; line-height: 1.3; }
    .product-desc { font-size: 0.78rem; color: #666; line-height: 1.5; margin-bottom: 0.85rem; }
    .product-footer { display: flex; align-items: center; justify-content: space-between; }
    .product-price { font-size: 1.1rem; font-weight: 700; color: var(--green-deep); }
    .product-price .was { font-size: 0.76rem; color: #999; text-decoration: line-through; font-weight: 400; margin-left: 0.3rem; }
    .btn-add { background: var(--green-deep); color: var(--white); border: none; padding: 0.48rem 0.9rem; font-size: 0.76rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s; }
    .btn-add:hover { background: var(--green-light); }

    /* ── PRODUCT DETAIL MODAL ── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 500;
      display: flex; align-items: center; justify-content: center; padding: 1.5rem;
      opacity: 0; pointer-events: none; transition: opacity 0.25s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--white); border-radius: 4px; max-width: 720px; width: 100%;
      box-shadow: 0 24px 64px rgba(0,0,0,0.3); overflow: hidden;
      transform: translateY(24px); transition: transform 0.25s;
      max-height: 90vh; overflow-y: auto;
    }
    .modal-overlay.open .modal { transform: translateY(0); }
    .modal-inner { display: grid; grid-template-columns: 1fr 1fr; }
    .modal-img { height: 360px; display: flex; align-items: center; justify-content: center; font-size: 6rem; position: relative; }
    .modal-badge { position: absolute; top: 1rem; left: 1rem; background: var(--gold); color: var(--green-deep); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.25rem 0.6rem; border-radius: 1px; }
    .modal-body { padding: 2rem 2rem 2rem; display: flex; flex-direction: column; }
    .modal-close { position: absolute; top: 1rem; right: 1rem; background: rgba(0,0,0,0.5); color: white; border: none; width: 2rem; height: 2rem; border-radius: 50%; font-size: 1.1rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 10; }
    .modal-close:hover { background: rgba(0,0,0,0.8); }
    .modal .product-category { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--green-light); margin-bottom: 0.4rem; }
    .modal-title { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 900; color: var(--charcoal); margin-bottom: 0.5rem; line-height: 1.25; }
    .modal-price { font-size: 1.5rem; font-weight: 700; color: var(--green-deep); margin-bottom: 1rem; }
    .modal-price .was { font-size: 0.9rem; color: #999; text-decoration: line-through; font-weight: 400; margin-left: 0.4rem; }
    .modal-desc { font-size: 0.9rem; color: #555; line-height: 1.7; margin-bottom: 1.25rem; flex: 1; }
    .modal-details { font-size: 0.78rem; color: #777; margin-bottom: 1.5rem; line-height: 1.8; }
    .modal-details strong { color: var(--charcoal); }
    .modal-qty { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.25rem; }
    .modal-qty label { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: #555; }
    .qty-ctrl { display: flex; align-items: center; border: 1.5px solid #d0c9be; border-radius: 2px; overflow: hidden; }
    .qty-ctrl button { background: var(--cream-dark); border: none; width: 2rem; height: 2rem; font-size: 1rem; cursor: pointer; transition: background 0.15s; }
    .qty-ctrl button:hover { background: #e0d9ce; }
    .qty-ctrl span { width: 2.5rem; text-align: center; font-size: 0.9rem; font-weight: 600; }
    .modal-actions { display: flex; gap: 0.75rem; }
    .btn-modal-add { flex: 1; background: var(--green-deep); color: var(--white); border: none; padding: 0.85rem; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s; }
    .btn-modal-add:hover { background: var(--green-light); }
    .btn-modal-buy { flex: 1; background: var(--gold); color: var(--green-deep); border: none; padding: 0.85rem; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s; }
    .btn-modal-buy:hover { background: var(--gold-light); }
    @media (max-width: 580px) {
      .modal-inner { grid-template-columns: 1fr; }
      .modal-img { height: 220px; }
    }

    /* ── CART DRAWER ── */
    .cart-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 400;
      opacity: 0; pointer-events: none; transition: opacity 0.25s;
    }
    .cart-overlay.open { opacity: 1; pointer-events: all; }
    .cart-drawer {
      position: fixed; top: 0; right: 0; bottom: 0; width: 400px; max-width: 100vw;
      background: var(--white); z-index: 401; box-shadow: -8px 0 40px rgba(0,0,0,0.2);
      display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform 0.3s ease;
    }
    .cart-overlay.open .cart-drawer { transform: translateX(0); }
    .cart-header {
      background: var(--green-deep); color: var(--white);
      padding: 1.1rem 1.5rem; display: flex; align-items: center; justify-content: space-between;
      border-bottom: 3px solid var(--gold);
    }
    .cart-header h3 { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 700; }
    .cart-close { background: none; border: none; color: var(--white); font-size: 1.4rem; cursor: pointer; line-height: 1; padding: 0.2rem; }
    .cart-items { flex: 1; overflow-y: auto; padding: 1rem; }
    .cart-empty { text-align: center; padding: 3rem 1.5rem; color: #888; }
    .cart-empty .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
    .cart-empty p { font-size: 0.9rem; line-height: 1.6; }
    .cart-item { display: flex; gap: 0.85rem; padding: 0.85rem 0; border-bottom: 1px solid #f0ebe0; align-items: flex-start; }
    .ci-emoji { font-size: 2.2rem; width: 3rem; text-align: center; flex-shrink: 0; background: var(--cream); border-radius: 2px; padding: 0.35rem; }
    .ci-info { flex: 1; }
    .ci-name { font-family: 'Playfair Display', serif; font-size: 0.9rem; font-weight: 700; color: var(--charcoal); margin-bottom: 0.2rem; }
    .ci-price { font-size: 0.82rem; color: var(--green-deep); font-weight: 600; margin-bottom: 0.4rem; }
    .ci-qty { display: flex; align-items: center; gap: 0.5rem; }
    .ci-qty button { background: var(--cream-dark); border: 1px solid #d0c9be; width: 1.6rem; height: 1.6rem; border-radius: 2px; font-size: 0.9rem; cursor: pointer; transition: background 0.15s; }
    .ci-qty button:hover { background: #d9d1c7; }
    .ci-qty span { font-size: 0.85rem; font-weight: 600; min-width: 1.2rem; text-align: center; }
    .ci-remove { background: none; border: none; color: #bbb; font-size: 1.1rem; cursor: pointer; padding: 0.2rem; transition: color 0.15s; flex-shrink: 0; margin-top: 0.1rem; }
    .ci-remove:hover { color: #e53935; }
    .cart-footer { padding: 1.25rem 1.5rem; border-top: 1px solid #e0d9ce; background: var(--cream); }
    .cart-subtotal { display: flex; justify-content: space-between; font-size: 0.88rem; margin-bottom: 0.4rem; color: #555; }
    .cart-total { display: flex; justify-content: space-between; font-size: 1.05rem; font-weight: 700; color: var(--green-deep); margin-bottom: 1.25rem; padding-top: 0.5rem; border-top: 1px solid #d9d1c7; }
    .btn-checkout {
      width: 100%; background: var(--green-deep); color: var(--white); border: none;
      padding: 1rem; font-size: 0.9rem; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s; margin-bottom: 0.6rem;
    }
    .btn-checkout:hover { background: var(--green-light); }
    .square-note { font-size: 0.7rem; color: #888; text-align: center; line-height: 1.5; }
    /* Square payment form inside cart */
    #square-payment-form { margin-top: 1rem; display: none; }
    #square-payment-form.visible { display: block; }
    #card-container { margin-bottom: 0.75rem; }
    #payment-status { font-size: 0.8rem; color: var(--green-deep); text-align: center; margin-top: 0.5rem; min-height: 1.2rem; }

    /* ── HERITAGE ── */
    .heritage { background: var(--green-deep); color: var(--white); text-align: center; padding: 5rem 2rem; position: relative; overflow: hidden; }
    .heritage::before { content: '☘'; position: absolute; font-size: 28rem; opacity: 0.04; top: 50%; left: 50%; transform: translate(-50%,-50%); line-height: 1; }
    .heritage-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
    .heritage-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem,4vw,2.7rem); font-weight: 900; margin-bottom: 1rem; line-height: 1.15; }
    .heritage-title em { color: var(--gold); font-style: italic; }
    .heritage-text { font-size: 1rem; color: #c8e6c9; line-height: 1.75; margin-bottom: 2rem; font-weight: 300; }
    .heritage-flags { display: flex; justify-content: center; gap: 2rem; font-size: 2.5rem; margin-bottom: 2rem; }

    /* ── TESTIMONIALS ── */
    .testimonials { background: var(--cream-dark); }
    .testi-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(260px,1fr)); gap: 1.25rem; max-width: 1000px; margin: 0 auto; }
    .testi-card { background: var(--white); border: 1px solid #e0d9ce; border-left: 4px solid var(--gold); padding: 1.5rem; border-radius: 2px; }
    .testi-stars { color: var(--gold); font-size: 0.9rem; margin-bottom: 0.75rem; }
    .testi-text { font-size: 0.88rem; line-height: 1.65; color: #444; font-style: italic; margin-bottom: 1rem; }
    .testi-author { font-size: 0.78rem; font-weight: 600; color: var(--green-deep); letter-spacing: 0.05em; }
    .testi-location { font-size: 0.72rem; color: #888; }

    /* ── NEWSLETTER ── */
    .newsletter { background: var(--gold); padding: 3.5rem 2rem; text-align: center; }
    .newsletter-title { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 900; color: var(--green-deep); margin-bottom: 0.5rem; }
    .newsletter-sub { font-size: 0.88rem; color: #5a3e00; margin-bottom: 1.5rem; }
    .newsletter-form { display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap; }
    .newsletter-form input { padding: 0.75rem 1.25rem; font-size: 0.88rem; border: 2px solid var(--green-deep); border-radius: 2px; width: 300px; background: var(--white); color: var(--charcoal); font-family: 'Inter', sans-serif; }
    .newsletter-form input:focus { outline: none; }
    .newsletter-form button { background: var(--green-deep); color: var(--white); border: none; padding: 0.75rem 1.75rem; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; border-radius: 2px; transition: background 0.2s; }
    .newsletter-form button:hover { background: var(--green-light); }

    /* ── FOOTER ── */
    footer { background: #0d1f0e; color: #a5c8a7; padding: 3rem 2rem 1.5rem; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; max-width: 1100px; margin: 0 auto 2rem; }
    .footer-brand .logo-text { font-family: 'Playfair Display', serif; font-size: 1.1rem; color: var(--gold); font-weight: 700; margin-bottom: 0.75rem; }
    .footer-brand p { font-size: 0.8rem; line-height: 1.7; color: #7ea880; }
    .footer-col h4 { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
    .footer-col ul { list-style: none; }
    .footer-col ul li { margin-bottom: 0.5rem; }
    .footer-col ul a { color: #7ea880; text-decoration: none; font-size: 0.8rem; transition: color 0.2s; }
    .footer-col ul a:hover { color: var(--gold); }
    .footer-bottom { border-top: 1px solid #1e3a20; padding-top: 1.25rem; text-align: center; font-size: 0.72rem; color: #4a6b4c; max-width: 1100px; margin: 0 auto; }
    .footer-bottom .shamrock { color: var(--gold); }

    /* ── TOAST ── */
    .cart-toast { position: fixed; bottom: 2rem; right: 2rem; background: var(--green-deep); color: var(--white); border-left: 4px solid var(--gold); padding: 0.9rem 1.4rem; border-radius: 3px; font-size: 0.85rem; box-shadow: 0 8px 32px rgba(0,0,0,0.25); transform: translateY(120px); opacity: 0; transition: all 0.3s ease; z-index: 999; }
    .cart-toast.show { transform: translateY(0); opacity: 1; }

    /* ── HERALDIC SECTION ── */
    .heraldic-section { background: var(--cream-dark); }
    .section-sub { font-size: 0.9rem; color: #666; margin-top: 0.5rem; }
    .heraldic-inner { max-width: 800px; margin: 0 auto; }
    .heraldic-search-wrap {
      position: relative;
      max-width: 420px;
      margin: 0 auto 2rem;
    }
    .heraldic-search-wrap input {
      width: 100%;
      padding: 0.85rem 2.5rem 0.85rem 1.1rem;
      font-size: 1rem;
      font-family: 'Inter', sans-serif;
      border: 2px solid #d0c9be;
      border-radius: 3px;
      background: var(--white);
      color: var(--charcoal);
      transition: border-color 0.2s;
    }
    .heraldic-search-wrap input:focus { outline: none; border-color: var(--green-deep); }
    .heraldic-search-icon {
      position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%);
      font-size: 1rem; pointer-events: none; color: #888;
    }
    .surname-dropdown {
      position: absolute; top: calc(100% + 4px); left: 0; right: 0;
      background: var(--white); border: 1px solid #e0d9ce; border-radius: 3px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.12); z-index: 300;
      max-height: 240px; overflow-y: auto; display: none;
    }
    .surname-dropdown.open { display: block; }
    .surname-option {
      padding: 0.65rem 1rem; cursor: pointer; font-size: 0.9rem;
      color: var(--charcoal); border-bottom: 1px solid #f5f0e8;
      transition: background 0.15s;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .surname-option:last-child { border-bottom: none; }
    .surname-option:hover { background: var(--cream); }
    .surname-option .crest-icon { font-size: 1.1rem; }
    .surname-no-match { padding: 0.75rem 1rem; font-size: 0.85rem; color: #888; text-align: center; }

    /* Heraldic product cards */
    .heraldic-result { display: none; }
    .heraldic-result.visible { display: block; }
    .heraldic-surname-banner {
      text-align: center; margin-bottom: 1.75rem;
      padding: 1.25rem; background: var(--green-deep); border-radius: 3px;
      border: 2px solid var(--gold);
    }
    .heraldic-surname-banner .crest-display { margin-bottom: 0.75rem; display:flex; justify-content:center; }
    .heraldic-surname-banner h3 {
      font-family: 'Playfair Display', serif; font-size: 1.4rem;
      color: var(--gold); font-weight: 900; margin-bottom: 0.25rem;
    }
    .heraldic-surname-banner p { font-size: 0.82rem; color: #c8e6c9; }
    .heraldic-products {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem;
    }
    @media (max-width: 600px) { .heraldic-products { grid-template-columns: 1fr; } }
    .heraldic-card {
      background: var(--white); border: 1px solid #e0d9ce; border-radius: 3px;
      overflow: hidden; text-align: center; transition: box-shadow 0.2s, transform 0.2s;
    }
    .heraldic-card:hover { box-shadow: 0 6px 24px rgba(27,94,32,0.13); transform: translateY(-3px); }
    .heraldic-card-img {
      background: linear-gradient(160deg, #0d2e10 0%, #1B5E20 100%);
      padding: 1.5rem 1.5rem 1rem;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 180px;
    }
    .heraldic-card-img svg { filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4)); }
    .heraldic-card-img .h-badge {
      position: absolute; top: 0.6rem; right: 0.6rem;
      background: var(--gold); color: var(--green-deep);
      font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
      text-transform: uppercase; padding: 0.18rem 0.45rem; border-radius: 1px;
    }
    .heraldic-card-body { padding: 1rem 1rem 1.25rem; }
    .heraldic-card-name {
      font-family: 'Playfair Display', serif; font-size: 1rem;
      font-weight: 700; color: var(--charcoal); margin-bottom: 0.25rem;
    }
    .heraldic-card-desc { font-size: 0.76rem; color: #777; margin-bottom: 0.75rem; line-height: 1.5; }
    .heraldic-card-price { font-size: 1.1rem; font-weight: 700; color: var(--green-deep); margin-bottom: 0.75rem; }
    .btn-heraldic-add {
      width: 100%; background: var(--green-deep); color: var(--white);
      border: none; padding: 0.6rem; font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0.06em; text-transform: uppercase; cursor: pointer;
      border-radius: 2px; transition: background 0.2s;
    }
    .btn-heraldic-add:hover { background: var(--green-light); }

    /* ── FIND YOUR ROOTS ── */
    .roots-section { background: var(--white); padding: 5rem 2rem; }
    .roots-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
    .roots-title { font-family: 'Playfair Display', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 900; color: var(--green-deep); line-height: 1.15; margin-bottom: 1rem; }
    .roots-title em { color: var(--gold); font-style: italic; }
    .roots-body { font-size: 0.92rem; color: #555; line-height: 1.75; margin-bottom: 1rem; }
    .roots-links { display: flex; flex-direction: column; gap: 0.75rem; margin: 1.5rem 0; }
    .roots-link { display: flex; align-items: center; gap: 1rem; background: var(--cream); border: 1.5px solid #e0d9ce; border-left: 4px solid var(--green-deep); padding: 0.85rem 1rem; border-radius: 3px; text-decoration: none; color: var(--charcoal); transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s; }
    .roots-link:hover { border-left-color: var(--gold); box-shadow: 0 4px 16px rgba(27,94,32,0.1); transform: translateX(3px); }
    .roots-link-icon { font-size: 1.5rem; flex-shrink: 0; }
    .roots-link div { flex: 1; }
    .roots-link strong { display: block; font-size: 0.88rem; color: var(--green-deep); margin-bottom: 0.15rem; }
    .roots-link span { font-size: 0.76rem; color: #777; line-height: 1.4; }
    .roots-link-arrow { font-size: 1rem; color: var(--gold); font-weight: 700; flex-shrink: 0; }
    .roots-note { font-size: 0.8rem; color: #888; font-style: italic; margin-top: 0.5rem; }
    .roots-map-card { background: var(--green-deep); color: var(--white); border-radius: 4px; padding: 2rem; border: 3px solid var(--gold); position: sticky; top: 80px; }
    .roots-map-emoji { font-size: 3.5rem; margin-bottom: 1rem; }
    .roots-map-card h3 { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--gold); margin-bottom: 0.75rem; }
    .roots-map-card p { font-size: 0.85rem; color: #c8e6c9; line-height: 1.7; margin-bottom: 1.5rem; }
    .roots-map-card p strong { color: var(--gold-light); }
    .roots-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-bottom: 0.5rem; }
    .roots-stat { text-align: center; background: rgba(255,255,255,0.08); border-radius: 3px; padding: 0.75rem 0.5rem; }
    .roots-stat-num { display: block; font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--gold); }
    .roots-stat-label { display: block; font-size: 0.65rem; color: #a5c8a7; letter-spacing: 0.05em; text-transform: uppercase; margin-top: 0.2rem; line-height: 1.3; }
    @media (max-width: 860px) { .roots-inner { grid-template-columns: 1fr; gap: 2.5rem; } }

    /* ── TOURIST NOTES ── */
    .notes-section { background: var(--cream-dark); padding: 4rem 2rem; }
    .notes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; max-width: 1100px; margin: 0 auto; }
    @media (max-width: 960px) { .notes-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 600px) { .notes-grid { grid-template-columns: 1fr; } }
    .notes-card {
      background: var(--white); border: 1px solid #e0d9ce;
      border-top: 4px solid var(--gold);
      border-radius: 3px; padding: 2rem 1.5rem 2rem;
      display: flex; flex-direction: column;
    }
    .notes-icon { font-size: 2rem; margin-bottom: 0.85rem; }
    .notes-card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.05rem; font-weight: 900;
      color: var(--green-deep); margin-bottom: 1rem;
      line-height: 1.3;
    }
    .notes-card p {
      font-size: 0.87rem; color: #555;
      line-height: 1.85; font-weight: 300;
    }

  
      .nav-links { display: none; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .trust-banner { gap: 1rem; }
    }

const BIRTHSTONE_MONTHS = {};








function isBirthstone(item) {
  const n = item.n.toLowerCase();
  return n.includes('birthstone') || (n.includes('claddagh') && (n.includes('january') || n.includes('february') || n.includes('march') || n.includes('april') || n.includes('may') || n.includes('june') || n.includes('july') || n.includes('august') || n.includes('september') || n.includes('october') || n.includes('november') || n.includes('december')));
}

function getProductImage(item) {
  if (PRODUCT_IMAGES[item.n]) return PRODUCT_IMAGES[item.n];
  // Check month-specific birthstone ring image
  const nl = item.n.toLowerCase();
  for (const [month, img] of Object.entries(BIRTHSTONE_MONTHS)) {
    if (nl.includes(month) && (nl.includes('claddagh') || nl.includes('birthstone') || nl.includes('ring'))) {
      return img;
    }
  }
  if (isBirthstone(item)) return BIRTHSTONE_IMG;
  return null;
}

function renderCard(item) {
  const img = getProductImage(item);
  const imgHtml = img ? `<div style="height:180px;overflow:hidden;background:#f5f2eb;"><img src="${img}" alt="${item.n}" style="width:100%;height:100%;object-fit:cover;object-position:center;"/></div>` : '';
  return `<div style="background:white;border:1.5px solid #e0dbd0;border-radius:3px;display:flex;flex-direction:column;overflow:hidden;transition:box-shadow 0.2s;" onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,0.08)'" onmouseout="this.style.boxShadow='none'">
    ${imgHtml}
    <div style="padding:1rem 1rem 0.5rem;flex:1;">
      ${item.c ? '<div style=\"font-size:0.62rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#C9A84C;margin-bottom:0.4rem;\">' + item.c + '</div>' : ''}
      <div style="font-size:0.86rem;font-weight:700;color:#1C1C1C;line-height:1.35;margin-bottom:0.4rem;">${item.n}</div>
      <div style="font-size:0.76rem;color:#777;line-height:1.55;">${item.d}</div>
    </div>
    <div style="padding:0.75rem 1rem;border-top:1px solid #f0ebe0;display:flex;align-items:center;justify-content:space-between;background:#fafaf8;">
      <div style="font-size:1rem;font-weight:800;color:#1B5E20;font-family:'Playfair Display',serif;">$${item.p.toFixed(2)}</div>
      <a href="${enquireLink(item)}" style="background:#1B5E20;color:white;text-decoration:none;padding:0.4rem 0.85rem;border-radius:2px;font-size:0.72rem;font-weight:700;letter-spacing:0.06em;">✉ Enquire</a>
    </div>
  </div>`;
}

function filterProducts() {
  const q = document.getElementById('prodSearch').value.toLowerCase();
  const sort = document.getElementById('prodSort').value;
  let items = [...PROD_DATA[currentTab]];
  if (q) items = items.filter(i => i.n.toLowerCase().includes(q) || i.d.toLowerCase().includes(q) || i.c.toLowerCase().includes(q));
  if (sort === 'price-asc') items.sort((a,b) => a.p - b.p);
  else if (sort === 'price-desc') items.sort((a,b) => b.p - a.p);
  else items.sort((a,b) => a.n.localeCompare(b.n));
  filteredItems = items;
  currentPage = 0;
  renderPage();
}

function renderPage() {
  const grid = document.getElementById('prodGrid');
  const start = currentPage * PAGE_SIZE;
  const slice = filteredItems.slice(0, start + PAGE_SIZE);
  grid.innerHTML = slice.map(renderCard).join('');
  document.getElementById('prodCount').textContent = filteredItems.length + ' items';
  const btn = document.getElementById('prodLoadMore');
  btn.style.display = slice.length < filteredItems.length ? 'inline-block' : 'none';
}

function loadMore() {
  currentPage++;
  renderPage();
}

function switchProdTab(tab, btn) {
  currentTab = tab;
  document.querySelectorAll('.prod-tab').forEach(t => {
    t.style.borderBottomColor = 'transparent';
    t.style.color = '#888';
  });
  btn.style.borderBottomColor = '#1B5E20';
  btn.style.color = '#1B5E20';
  document.getElementById('prodSearch').value = '';
  filterProducts();
}

